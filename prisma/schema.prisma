datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  examType      String?
  examDate      DateTime?
  accounts      Account[]
  sessions      Session[]
  streak        Streak?
  journalEntries JournalEntry[]
  moodCheckIns   MoodCheckIn[]
}

model MoodCheckIn {
  id          String   @id @default(cuid())
  userId      String
  moodScore   Int
  energyLevel Int
  triggers    String?  // Comma-separated list of triggers
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  content   String
  mood      String?
  moodScore Int?
  prompt    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}



model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Streak {
  id          String   @id @default(cuid())
  userId      String   @unique
  count       Int      @default(0)
  lastUpdated DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
